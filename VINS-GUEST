<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hidden Place — The Hang Out</title>
    <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Barlow+Condensed:wght@300;400;600;700&family=Courier+Prime:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #0A0705;
            --card: rgba(14,9,5,0.94);
            --input-bg: rgba(22,14,8,0.97);
            --border: rgba(255,185,55,0.15);
            --border-hi: rgba(255,185,55,0.3);
            --gold: #E8A020;
            --red: #B83025;
            --red2: #E74C3C;
            --text: #F5EDD8;
            --muted: rgba(245,237,216,0.45);
        }

        html, body {
            min-height: 100vh;
            background: var(--bg);
            color: var(--text);
            font-family: "Barlow Condensed", sans-serif;
            overflow-x: hidden;
        }

        /* ── SCROLLING TICKER ── */
        #message-ticker {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(232,160,32,0.12);
            border-bottom: 1px solid rgba(232,160,32,0.25);
            padding: 10px 16px;
            z-index: 100;
            overflow: hidden;
            height: 40px;
            display: flex;
            align-items: center;
        }

        .ticker-content {
            display: inline-block;
            animation: scroll-left 25s linear infinite;
            font-family: "Courier Prime", monospace;
            font-size: 13px;
            color: rgba(232,160,32,0.85);
            white-space: nowrap;
        }

        @keyframes scroll-left {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        /* ── JUKEBOX SIDEBAR ── */
        #jukebox-sidebar {
            position: fixed;
            left: 0;
            top: 50px;
            width: 200px;
            height: calc(100vh - 50px);
            background: rgba(10,7,5,0.98);
            border-right: 1px solid var(--border);
            padding: 16px 12px;
            overflow-y: auto;
            z-index: 50;
            display: none;
        }

        #jukebox-sidebar.active {
            display: block;
        }

        .sidebar-title {
            font-size: 10px;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--muted);
            font-family: "Courier Prime", monospace;
            margin-bottom: 10px;
        }

        .queue-item {
            padding: 8px;
            margin-bottom: 8px;
            background: rgba(232,160,32,0.08);
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 11px;
            color: var(--text);
        }

        .queue-position {
            font-size: 12px;
            color: var(--gold);
            margin-bottom: 12px;
            padding: 10px;
            background: rgba(232,160,32,0.12);
            border-radius: 6px;
        }

        /* ── PAGE WRAPPER ── */
        #page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-bottom: 72px;
            margin-top: 40px;
        }

        /* ── JUKEBOX BUTTON ── */
        #jukebox-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #8B4513, #D2691E);
            border: none;
            border-radius: 12px;
            color: var(--text);
            font-family: "Barlow Condensed", sans-serif;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 12px;
            display: none;
        }

        #jukebox-btn.active {
            display: block;
        }

        /* ── JUKEBOX MODAL ── */
        #jukebox-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            z-index: 200;
            display: none;
            align-items: center;
            justify-content: center;
        }

        #jukebox-modal.open {
            display: flex;
        }

        .jukebox-content {
            background: var(--card);
            border: 1px solid var(--border-hi);
            border-radius: 16px;
            padding: 24px;
            max-width: 400px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
        }

        .jukebox-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 16px;
            color: var(--gold);
        }

        .song-search {
            width: 100%;
            padding: 12px;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-family: "Barlow Condensed", sans-serif;
            margin-bottom: 12px;
        }

        .song-item {
            padding: 12px;
            background: rgba(232,160,32,0.08);
            border: 1px solid var(--border);
            border-radius: 6px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .song-item:hover {
            background: rgba(232,160,32,0.15);
            border-color: var(--gold);
        }

        .pricing-info {
            background: rgba(184,48,37,0.1);
            border: 1px solid rgba(184,48,37,0.3);
            border-radius: 8px;
            padding: 12px;
            margin: 16px 0;
            font-size: 12px;
            color: var(--text);
        }

        .expedite-btn {
            width: 100%;
            padding: 11px;
            background: rgba(232,160,32,0.2);
            border: 1px solid rgba(232,160,32,0.4);
            border-radius: 8px;
            color: var(--gold);
            font-family: "Barlow Condensed", sans-serif;
            font-size: 12px;
            cursor: pointer;
            margin-top: 12px;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: none;
            border: none;
            color: var(--text);
            font-size: 24px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <!-- SCROLLING TICKER -->
    <div id="message-ticker">
        <div class="ticker-content" id="ticker-text">Welcome to Hidden Place — The Hang Out! 🎸</div>
    </div>

    <!-- JUKEBOX SIDEBAR -->
    <div id="jukebox-sidebar">
        <div class="sidebar-title">🎵 Queue Status</div>
        <div class="queue-position" id="queue-pos">Your Position: —</div>
        
        <div class="sidebar-title">Songs Ahead</div>
        <div id="queue-list"></div>

        <div class="sidebar-title" style="margin-top: 16px;">Request Price</div>
        <div style="font-size: 12px; color: var(--text); padding: 8px; background: rgba(232,160,32,0.08); border-radius: 6px;">
            <p>🎵 Base: ₹10</p>
            <p>⚡ Expedite: +₹5</p>
        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div id="page">
        <!-- Your existing page content goes here -->
        <div style="padding: 20px; text-align: center; max-width: 420px;">
            <h1 style="color: var(--gold); margin-bottom: 20px;">Hidden Place — The Hang Out</h1>
            <p style="color: var(--muted); margin-bottom: 20px;">Experience great music and vibes</p>
            
            <!-- JUKEBOX REQUEST BUTTON -->
            <button id="jukebox-btn" onclick="openJukeboxModal()">🎵 Request a Song · ₹10</button>
        </div>
    </div>

    <!-- JUKEBOX MODAL -->
    <div id="jukebox-modal">
        <div class="jukebox-content">
            <button class="modal-close" onclick="closeJukeboxModal()">✕</button>
            <div class="jukebox-title">🎵 Request a Song</div>
            
            <input type="text" class="song-search" id="song-search" placeholder="Search songs...">
            
            <div id="song-list"></div>
            
            <div class="pricing-info">
                <strong>💰 Pricing:</strong><br>
                Standard: ₹10<br>
                Expedite (Jump Queue): +₹5
            </div>

            <button class="expedite-btn" onclick="expediteSong()">⚡ Expedite for ₹5</button>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, addDoc, onSnapshot, doc, updateDoc, query, where, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAqBkxofG2zyJSpKYFUG4OnNBANjrc-Qok",
            authDomain: "vtest-c064b.firebaseapp.com",
            projectId: "vtest-c064b",
            storageBucket: "vtest-c064b.firebasestorage.app",
            messagingSenderId: "906778127218",
            appId: "1:906778127218:web:5dd5f3e1c5d7c3f4e5c7d8"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const VENUE = new URLSearchParams(location.search).get("venue") || "hidden-place";

        // Check time for jukebox access
        function checkJukeboxAccess() {
            const now = new Date();
            const hours = now.getHours();
            const isActive = hours >= 12 && hours < 19;
            
            document.getElementById('jukebox-btn').classList.toggle('active', isActive);
            document.getElementById('jukebox-sidebar').classList.toggle('active', isActive);
        }

        // Load ticker messages
        onSnapshot(doc(db, "dj_messages", VENUE), (snap) => {
            if (snap.exists() && snap.data().messages) {
                const messages = snap.data().messages;
                let index = 0;
                const tickerEl = document.getElementById('ticker-text');
                
                setInterval(() => {
                    tickerEl.textContent = messages[index % messages.length];
                    index++;
                }, 15000);
            }
        });

        // Load queue
        onSnapshot(query(collection(db, "jukebox_requests"), where("venueId", "==", VENUE)), (snap) => {
            const queueList = document.getElementById('queue-list');
            const songs = [];
            
            snap.forEach(doc => {
                songs.push(doc.data().song);
            });

            queueList.innerHTML = songs.map((song, i) => 
                `<div class="queue-item">${i + 1}. ${song}</div>`
            ).join('');

            document.getElementById('queue-pos').textContent = `Your Position: ${songs.length + 1}`;
        });

        window.openJukeboxModal = () => {
            document.getElementById('jukebox-modal').classList.add('open');
        };

        window.closeJukeboxModal = () => {
            document.getElementById('jukebox-modal').classList.remove('open');
        };

        window.expediteSong = () => {
            alert('Song expedited for ₹5! Your song will be played sooner.');
        };

        checkJukeboxAccess();
        setInterval(checkJukeboxAccess, 60000);
    </script>
</body>
</html>
